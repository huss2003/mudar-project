    {
      "id": "code-budget",
      "name": "Calculate Budget",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [750, 300],
      "parameters": {
        "language": "javascript",
        "code": "const items = $input.all();\nconst dailyCapCents = 2000;\nconst byLayer = {};\nlet totalCostCents = 0;\n\nfor (const item of items) {\n  const layerId = item.json.layer_id || \"unknown\";\n  const costCents = parseInt(item.json.cost_cents) || 0;\n  if (!byLayer[layerId]) byLayer[layerId] = 0;\n  byLayer[layerId] += costCents;\n  totalCostCents += costCents;\n}\n\nconst budgetPercent = dailyCapCents > 0 ? (totalCostCents / dailyCapCents) * 100 : 0;\nconst roundedPct = Math.round(budgetPercent * 100) / 100;\n\nlet status = \"normal\";\nif (roundedPct >= 100) {\n  status = \"critical\";\n} else if (roundedPct >= 80) {\n  status = \"warning\";\n}\n\nconst totalDollars = (totalCostCents / 100).toFixed(2);\n\nreturn {\n  total_cost_cents: totalCostCents,\n  by_layer: byLayer,\n  budget_percent: roundedPct,\n  status: status,\n  daily_cap_cents: dailyCapCents,\n  warning_message: \"\\u26A0\\uFE0F *Budget Warning*\\nDaily AI cost exceeds 80% of $20 cap.\\n\\n\\u{1F4CA} *Usage:* $\" + totalDollars + \" / $20.00 (\" + roundedPct + \"%)\\n\\n\\u{1F50D} *By Layer:* \" + JSON.stringify(byLayer),\n  critical_message: \"\\u{1F6A8} *Critical Budget Alert*\\nDaily AI cost reached/exceeded $20 cap!\\n\\n\\u{1F4CA} *Usage:* $\" + totalDollars + \" / $20.00 (\" + roundedPct + \"%)\\n\\n\\u{1F50D} *By Layer:* \" + JSON.stringify(byLayer)\n};"
      }
    },
    {
      "id": "if-warning",
      "name": "IF Warning",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [1000, 300],
      "parameters": {
        "conditions": {
          "string": {
            "value1": "={{ $json.status }}",
            "value2": "warning"
          }
        }
      }
    },
    {
