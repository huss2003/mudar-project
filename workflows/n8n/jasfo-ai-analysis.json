    {
      "id": "node-validate-009",
      "name": "Code - Validate Schema",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2000,
        300
      ],
      "parameters": {
        "jsCode": "const input = $input.first().json;\nconst data = input.parsed || {};\n\nconst hasCompany = data.company && typeof data.company === 'object';\nconst hasCompanyName = hasCompany && typeof data.company.name === 'string' && data.company.name.length > 0;\nconst hasCompanyDomain = hasCompany && typeof data.company.domain === 'string' && data.company.domain.length > 0;\nconst hasCompanyDescription = hasCompany && typeof data.company.description === 'string';\nconst hasProducts = Array.isArray(data.products);\nconst hasTechnologies = Array.isArray(data.technologies);\nconst hasConfidence = data.confidence_scores && typeof data.confidence_scores === 'object';\n\nconst schemaValid = hasCompanyName && hasCompanyDomain && hasProducts && hasTechnologies;\n\nconst missingFields = [];\nif (!hasCompany) missingFields.push('company');\nif (!hasCompanyName) missingFields.push('company.name');\nif (!hasCompanyDomain) missingFields.push('company.domain');\nif (!hasCompanyDescription) missingFields.push('company.description');\nif (!hasProducts) missingFields.push('products');\nif (!hasTechnologies) missingFields.push('technologies');\nif (!hasConfidence) missingFields.push('confidence_scores');\n\nconst repairPrompt = schemaValid ? '' : 'Fix this JSON. Missing fields: ' + missingFields.join(', ') + '.\\n\\nInvalid JSON:\\n' + JSON.stringify(data, null, 2) + '\\n\\nReturn ONLY corrected JSON with all required fields.';\n\nconst validatedData = schemaValid ? {\n  company_name: data.company.name,\n  company_domain: data.company.domain,\n  company_data: data\n} : null;\n\nreturn [{\n  json: {\n    schemaValid,\n    validatedData,\n    confidenceScores: data.confidence_scores || null,\n    missingFields,\n    repairPrompt,\n    rawData: data\n  }\n}];"
      }
    },
