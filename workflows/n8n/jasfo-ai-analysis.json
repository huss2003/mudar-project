        "jsonBody": "{\"model\":\"deepseek-v4-flash\",\"messages\":[{\"role\":\"system\",\"content\":\"You are a JSON repair assistant. Fix malformed JSON to match the required schema. Return ONLY valid JSON, no explanation.\"},{\"role\":\"user\",\"content\":\"{{JSON.stringify($json.repairPrompt || $json.error || 'Fix this invalid JSON')\"}}\"],\"temperature\":0.1,\"max_tokens\":4096,\"response_format\":{\"type\":\"json_object\"}}",
