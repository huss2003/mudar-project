    {
      "id": "node-prep-002",
      "name": "Code - Prepare Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        500,
        500
      ],
      "parameters": {
        "jsCode": "const input = $input.first().json;\n\nconst systemPrompt = 'You are Jasfo AI, an expert business analysis system. Analyze companies based on provided data and extract structured intelligence.\\n\\nCRITICAL RULES:\\n1. Return ONLY valid JSON - no markdown, no code fences, no explanation\\n2. Extract real facts from the provided crawl data and search results\\n3. Do not fabricate or hallucinate data\\n4. Set confidence scores realistically based on data quality\\n5. If data is insufficient, note it in confidence scores\\n\\nRequired JSON structure:\\n{\\n  \"company\": {\\n    \"name\": \"Company name\",\\n    \"domain\": \"Company domain\",\\n    \"description\": \"2-3 sentence company description\",\\n    \"industry\": \"Primary industry\",\\n    \"founded_year\": null or number,\\n    \"employee_count\": null or string,\\n    \"headquarters\": \"Location or null\",\\n    \"social_links\": {}\\n  },\\n  \"products\": [\\n    {\\n      \"name\": \"Product name\",\\n      \"description\": \"Product description\",\\n      \"category\": \"Product category\",\\n      \"pricing_model\": \"subscription/freemium/one-time/etc or null\"\\n    }\\n  ],\\n  \"technologies\": [\\n    {\\n      \"name\": \"Technology name\",\\n      \"category\": \"Category (analytics/hosting/framework/cdn/marketing/payment/etc)\",\\n      \"description\": \"How it\\'s used or null\"\\n    }\\n  ],\\n  \"confidence_scores\": {\\n    \"overall\": 0-100,\\n    \"data_quality\": 0-100,\\n    \"completeness\": 0-100\\n  }\\n}';\n\nconst userPrompt = 'Analyze this company data and return the JSON structure:\\n\\nCompany Name: ' + (input.company_name || 'Unknown') + '\\nCompany Domain: ' + (input.company_domain || 'Unknown') + '\\n\\nCrawl Data:\\n' + JSON.stringify(input.crawl_data || {}, null, 2) + '\\n\\nSearch Results:\\n' + JSON.stringify(input.search_results || {}, null, 2) + '\\n\\nReturn ONLY valid JSON matching the required schema.';\n\nconst messages = [\n  { role: 'system', content: systemPrompt },\n  { role: 'user', content: userPrompt }\n];\n\nconst totalChars = systemPrompt.length + userPrompt.length;\nconst estimatedTokens = Math.ceil(totalChars / 3.5);\nconst modelChoice = estimatedTokens > 100000 ? 'mimo-v2.5' : 'deepseek-v4-flash';\n\nreturn [{\n  json: {\n    messages,\n    systemPrompt,\n    userPrompt,\n    estimatedTokens,\n    modelChoice\n  }\n}];"
      }
    },
    {
      "id": "node-if-token-003",
      "name": "IF - Token > 100K?",
