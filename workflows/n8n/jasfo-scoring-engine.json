    {
      "id": "parse-reflection",
      "name": "Parse Reflection",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2850, 300],
      "parameters": {
        "language": "javaScript",
        "code": "const response = $input.first().json;\nconst content = response?.choices?.[0]?.message?.content || response?.content || JSON.stringify(response);\nlet parsed;\ntry {\n  parsed = typeof content === 'string' ? JSON.parse(content) : content;\n} catch (e) {\n  parsed = { passed: false, reasoning: 'Failed to parse reflection: ' + e.message, adjustments: [] };\n}\n\nreturn {\n  reflection_passed: parsed.passed === true,\n  reflection_reasoning: parsed.reasoning || '',\n  reflection_adjustments: Array.isArray(parsed.adjustments) ? parsed.adjustments : [],\n  raw_reflection: typeof content === 'string' ? content.substring(0, 5000) : JSON.stringify(content).substring(0, 5000)\n};"
      }
    },
