      "parameters": {
        "language": "javascript",
        "code": "const wh = $node[\"Webhook\"].json.body;\nconst ex = $input.first().json;\n\nconst ctx = [\n  `Company: ${ex.company_name || wh.company_name}`,\n  `Domain: ${ex.company_domain || wh.company_domain}`,\n  `Description: ${ex.description || \"\"}`,\n  `Business Model: ${ex.business_model || \"\"}`,\n  `Revenue: ${ex.revenue || \"\"}`,\n  `Funding: ${ex.funding || \"\"}`,\n  `Employees: ${ex.employees || \"\"}`,\n  `Technologies: ${Array.isArray(ex.technologies) ? ex.technologies.join(\", \") : (ex.technologies || \"\")}`,\n  `Recent News: ${ex.recent_news || \"\"}`,\n  `Key People: ${ex.key_people || \"\"}`,\n  `Market Position: ${ex.market_position || \"\"}`,\n  `Growth Metrics: ${ex.growth_metrics || \"\"}`,\n  `Financial Data: ${ex.financial_data || \"\"}`,\n  `Decision Makers: ${ex.decision_makers || \"\"}`,\n  `Network Data: ${ex.network_data || \"\"}`\n].join(\"\\n\");\n\nreturn [{\n  json: {\n    run_id: wh.run_id,\n    company_name: ex.company_name || wh.company_name,\n    company_domain: ex.company_domain || wh.company_domain,\n    extraction_id: wh.extraction_id,\n    contextText: ctx\n  }\n}];"
      }
    },
