    {
      "id": "calculate-composite",
      "name": "Calculate Composite",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2450, 300],
      "parameters": {
        "language": "javaScript",
        "code": "function parseScore(nodeName) {\n  try {\n    const node = $(nodeName).first().json;\n    const content = node?.choices?.[0]?.message?.content;\n    if (!content) return { score: 0, reasoning: 'No content in response', confidence: 0, factors: [] };\n    const parsed = JSON.parse(content);\n    return {\n      score: typeof parsed.score === 'number' ? parsed.score : 0,\n      reasoning: parsed.reasoning || '',\n      confidence: typeof parsed.confidence === 'number' ? parsed.confidence : 0,\n      factors: Array.isArray(parsed.factors) ? parsed.factors : []\n    };\n  } catch (e) {\n    return { score: 0, reasoning: 'Parse error: ' + e.message, confidence: 0, factors: [] };\n  }\n}\n\nconst fit = parseScore('Score Company Fit');\nconst moveIntent = parseScore('Score Move Intent');\nconst growth = parseScore('Score Growth');\nconst financial = parseScore('Score Financial');\nconst dm = parseScore('Score Decision Maker');\nconst network = parseScore('Score Network');\nconst opportunity = parseScore('Score Opportunity');\nconst evidence = parseScore('Score Evidence');\n\nconst composite = \n  (moveIntent.score || 0) * 0.35 +\n  (growth.score || 0) * 0.15 +\n  (financial.score || 0) * 0.12 +\n  (fit.score || 0) * 0.10 +\n  (dm.score || 0) * 0.10 +\n  (network.score || 0) * 0.08 +\n  (opportunity.score || 0) * 0.05 +\n  (evidence.score || 0) * 0.05;\n\nconst riskFactors = [];\nif ((fit.score || 0) < 50) riskFactors.push('Low company fit');\nif ((moveIntent.score || 0) < 50) riskFactors.push('Low move intent');\nif ((growth.score || 0) < 50) riskFactors.push('Weak growth indicators');\nif ((financial.score || 0) < 50) riskFactors.push('Weak financial health');\nif ((dm.score || 0) < 50) riskFactors.push('No strong decision maker signal');\nif ((network.score || 0) < 50) riskFactors.push('Weak network connections');\nif ((opportunity.score || 0) < 50) riskFactors.push('Limited opportunity signal');\nif ((evidence.score || 0) < 50) riskFactors.push('Insufficient evidence');\n\nconst avgConfidence = (\n  (fit.confidence || 0) + (moveIntent.confidence || 0) +\n  (growth.confidence || 0) + (financial.confidence || 0) +\n  (dm.confidence || 0) + (network.confidence || 0) +\n  (opportunity.confidence || 0) + (evidence.confidence || 0)\n) / 8;\n\nreturn {\n  composite_score: Math.round(composite * 100) / 100,\n  pillar_scores: {\n    company_fit: fit,\n    move_intent: moveIntent,\n    growth: growth,\n    financial: financial,\n    decision_maker: dm,\n    network: network,\n    opportunity: opportunity,\n    evidence: evidence\n  },\n  confidence: Math.round(avgConfidence * 100) / 100,\n  risk_factors: riskFactors\n};"
      }
    },
