    {
      "name": "Aggregate Scores",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1250,
        330
      ],
      "parameters": {
        "language": "javascript",
        "code": "const items = $input.all();\nconst weights = {\n  company_fit: 0.10,\n  move_intent: 0.35,\n  growth_signal: 0.15,\n  financial_health: 0.12,\n  decision_maker_access: 0.10,\n  network_relationships: 0.08,\n  opportunity_timing: 0.05,\n  evidence_quality: 0.05\n};\n\nconst ctx = $node[\"Prepare Scoring Context\"].json;\nconst pillarScores = {};\nlet weightedSum = 0;\nlet totalW = 0;\n\nfor (const item of items) {\n  const resp = item.json;\n  const raw = resp.choices?.[0]?.message?.content;\n  if (!raw) continue;\n  try {\n    const parsed = JSON.parse(raw);\n    const pillar = parsed.pillar;\n    if (!pillar || !weights[pillar]) continue;\n    const score = Math.max(0, Math.min(100, Math.round(parsed.score || 0)));\n    pillarScores[pillar] = {\n      score,\n      justification: parsed.justification || \"\",\n      evidence: Array.isArray(parsed.evidence) ? parsed.evidence : [],\n      weight: weights[pillar]\n    };\n    weightedSum += score * weights[pillar];\n    totalW += weights[pillar];\n  } catch (e) {\n    continue;\n  }\n}\n\nconst compositeScore = totalW > 0 ? Math.round(weightedSum / totalW) : 0;\n\nconst riskFactors = [];\nfor (const [pillar, data] of Object.entries(pillarScores)) {\n  if (data.score < 40) {\n    riskFactors.push({\n      pillar,\n      score: data.score,\n      concern: `Low ${pillar.replace(/_/g, \" \")} score (${data.score}/100)`,\n      justification: data.justification\n    });\n  }\n}\n\nlet confidence = \"medium\";\nif (Object.keys(pillarScores).length >= 7) confidence = \"high\";\nelse if (Object.keys(pillarScores).length <= 4) confidence = \"low\";\n\nreturn [{\n  json: {\n    run_id: ctx.run_id,\n    company_name: ctx.company_name,\n    company_domain: ctx.company_domain,\n    pillar_scores: pillarScores,\n    composite_score: compositeScore,\n    confidence,\n    risk_factors: riskFactors,\n    pillar_count: Object.keys(pillarScores).length\n  }\n}];"
      }
    },
    {
      "name": "MiMo V2.5 Reflection",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        1450,
        330
      ],
      "parameters": {
        "method": "POST",
        "url": "https://api.mimo.ai/v1/chat/completions",
        "authentication": "genericCredentialType",
        "nodeCredentialType": "mimoApi",
        "sendBody": true,
        "bodyContentType": "json",
        "bodyParameters": {
          "parameters": [
            {
              "name": "model",
              "value": "mimo-v2.5"
            },
            {
              "name": "messages",
              "value": "={{ [{\"role\":\"system\",\"content\":\"You are a quality reflection agent. Review the scoring for consistency, accuracy, and bias.\"},{\"role\":\"user\",\"content\":\"Review this scoring for company \" + $json.company_name + \" (domain: \" + $json.company_domain + \").\\n\\nComposite Score: \" + $json.composite_score + \"/100\\nConfidence: \" + $json.confidence + \"\\n\\nPillar Scores:\\n\" + JSON.stringify($json.pillar_scores, null, 2) + \"\\n\\nRisk Factors:\\n\" + JSON.stringify($json.risk_factors, null, 2) + \"\\n\\nReturn JSON: {\\\"verdict\\\": \\\"PASS\\\" or \\\"FAIL\\\", \\\"issues\\\": [], \\\"suggested_adjustment\\\": null, \\\"reasoning\\\": \\\"...\\\"}\"}] }}",
              "parameterType": "expression"
            },
            {
              "name": "temperature",
              "value": 0.2
            },
            {
              "name": "response_format",
              "value": "={{ {\"type\":\"json_object\"} }}",
              "parameterType": "expression"
            }
          ]
        },
        "options": {}
      },
      "credentials": {
        "mimoApi": {
          "id": "__MIMO_CRED_ID__",
          "name": "MiMo V2.5 API"
        }
      }
    },
    {
      "name": "Parse Reflection",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1650,
        330
      ],
      "parameters": {
        "language": "javascript",
        "code": "const resp = $input.first().json;\nconst raw = resp.choices?.[0]?.message?.content || \"{}\";\nlet reflection;\ntry {\n  reflection = JSON.parse(raw);\n} catch (e) {\n  reflection = { verdict: \"FAIL\", issues: [\"Parse error: \" + e.message], reasoning: \"\" };\n}\n\nconst ctx = $node[\"Aggregate Scores\"].json;\nconst passed = reflection.verdict === \"PASS\";\nconst adj = typeof reflection.suggested_adjustment === \"number\" ? reflection.suggested_adjustment : ctx.composite_score;\n\nreturn [{\n  json: {\n    run_id: ctx.run_id,\n    company_name: ctx.company_name,\n    company_domain: ctx.company_domain,\n    pillar_scores: ctx.pillar_scores,\n    composite_score: adj,\n    original_composite: ctx.composite_score,\n    confidence: ctx.confidence,\n    risk_factors: ctx.risk_factors,\n    reflection_passed: passed,\n    reflection_verdict: reflection.verdict,\n    reflection_issues: reflection.issues || [],\n    reflection_reasoning: reflection.reasoning || \"\"\n  }\n}];"
      }
    },
    {
      "name": "Reflection Passed?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        1850,
        330
      ],
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "cond-passed",
              "leftValue": "={{ $json.reflection_passed }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        }
      }
    },
