      "id": "code-2",
      "name": "Build JSON",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1500, 100],
      "parameters": {
        "language": "javascript",
        "code": "const merged = $node[\"Merge Data\"].json;\nconst report = {\n  report: {\n    company: merged.company,\n    score_card: merged.score_card,\n    ai_extraction: merged.ai_extraction,\n    generated_at: new Date().toISOString()\n  }\n};\nreturn {\n  content: JSON.stringify(report, null, 2),\n  format: \"json\"\n};"
      }
    },
    {
      "id": "code-3",
      "name": "Build CSV",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1500, 300],
      "parameters": {
        "language": "javascript",
        "code": "const merged = $node[\"Merge Data\"].json;\nconst row = {\n  company_domain: merged.company_domain,\n  run_id: merged.run_id,\n  total_score: merged.score_card?.total_score || 0,\n  total_criteria: (merged.score_card?.criteria_results || []).length,\n  ai_summary: (merged.ai_extraction?.summary || \"\").replace(/,/g, \";\"),\n  company_industry: merged.company?.industry || \"\"\n};\nconst header = Object.keys(row).join(\",\");\nconst values = Object.values(row).map(v => typeof v === \"string\" && v.includes(\",\") ? `\"${v}\"` : v).join(\",\");\nreturn {\n  content: header + \"\\n\" + values,\n  format: \"csv\"\n};"
      }
    },
    {
      "id": "code-4",
      "name": "Build Markdown",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1500, 500],
      "parameters": {
        "language": "javascript",
        "code": "const merged = $node[\"Merge Data\"].json;\nconst sc = merged.score_card || {};\nconst ae = merged.ai_extraction || {};\nconst co = merged.company || {};\n\nlet md = \"# Score Card Report\\n\\n\";\nmd += `**Company:** ${merged.company_domain}\\n`;\nmd += `**Run ID:** ${merged.run_id}\\n`;\nmd += `**Total Score:** ${sc.total_score || \"N/A\"}\\n\\n`;\n\nif (sc.pillar_scores && Object.keys(sc.pillar_scores).length > 0) {\n  md += \"## Pillar Scores\\n\\n\";\n  md += \"| Pillar | Score |\\n|-------|-------|\\n\";\n  for (const [pillar, score] of Object.entries(sc.pillar_scores)) {\n    md += `| ${pillar} | ${score} |\\n`;\n  }\n  md += \"\\n\";\n}\n\nif (sc.criteria_results && sc.criteria_results.length > 0) {\n  md += \"## Criteria Results\\n\\n\";\n  md += \"| # | Criterion | Pass | Score |\\n|---|----------|------|-------|\\n\";\n  sc.criteria_results.forEach((c, i) => {\n    md += `| ${i + 1} | ${c.criterion || c.name || \"\"} | ${c.pass || c.passed ? \"✅\" : \"❌\"} | ${c.score || 0} |\\n`;\n  });\n  md += \"\\n\";\n}\n\nif (ae.summary) {\n  md += \"## AI Summary\\n\\n\" + ae.summary + \"\\n\\n\";\n}\n\nif (co.notes) {\n  md += \"## Company Notes\\n\\n\" + co.notes + \"\\n\";\n}\n\nmd += \"\\n---\\n_Generated: \" + new Date().toISOString() + \"_\";\n\nreturn {\n  content: md,\n  format: \"markdown\"\n};"
      }
    },
    {
      "id": "code-5",
      "name": "Build Telegram",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1500, 700],
      "parameters": {
        "language": "javascript",
        "code": "const merged = $node[\"Merge Data\"].json;\nconst sc = merged.score_card || {};\nconst ae = merged.ai_extraction || {};\nconst co = merged.company || {};\n\nlet text = \"\\u{1F4CA} *Score Card Report*\\n\\n\";\ntext += `\\u{1F3E2} *Company:* ${merged.company_domain}\\n`;\ntext += `\\u{1F522} *Run:* ${merged.run_id}\\n`;\ntext += `\\u{1F4C8} *Score:* ${sc.total_score || \"N/A\"}/100\\n\\n`;\n\nif (sc.pillar_scores && Object.keys(sc.pillar_scores).length > 0) {\n  text += \"*Pillar Scores:*\\n\";\n  for (const [pillar, score] of Object.entries(sc.pillar_scores)) {\n    const icon = score >= 80 ? \"\\u{1F7E2}\" : score >= 50 ? \"\\u{1F7E1}\" : \"\\u{1F534}\";\n    text += `${icon} *${pillar}:* ${score}\\n`;\n  }\n  text += \"\\n\";\n}\n\nif (ae.summary) {\n  text += `\\u{1F4DD} *Summary:* ${ae.summary.substring(0, 400)}\\n\\n`;\n}\n\nif (co.notes) {\n  text += `\\u{1F4CC} *Notes:* ${co.notes.substring(0, 200)}\\n\\n`;\n}\n\ntext += `\\u{23F0} _Generated: ${new Date().toISOString()}_`;\n\nreturn { text: text };"
      }
    },
