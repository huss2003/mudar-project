      "id": "code-1",
      "name": "Merge Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1000, 300],
      "parameters": {
        "language": "javascript",
        "code": "const scoreCard = $node[\"Get Score Card\"].json;\nconst aiExtraction = $node[\"Get AI Extraction\"].json;\nconst company = $node[\"Get Company\"].json;\nconst webhook = $node[\"Webhook\"].json;\n\nconst scoreCardData = Array.isArray(scoreCard) ? (scoreCard[0] || {}) : (scoreCard || {});\nconst aiExtractionData = Array.isArray(aiExtraction) ? (aiExtraction[0] || {}) : (aiExtraction || {});\nconst companyData = Array.isArray(company) ? (company[0] || {}) : (company || {});\n\nreturn {\n  run_id: webhook.run_id,\n  company_domain: webhook.company_domain,\n  export_format: webhook.export_format,\n  score_card_id: webhook.score_card_id,\n  score_card: scoreCardData,\n  ai_extraction: aiExtractionData,\n  company: companyData\n};"
      }
