    {
      "id": "4a7b8c9d-0e1f-4a3b-4c5d-6e7f8a9b0c1d",
      "name": "Calculate Duplicate Score",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1450, 200],
      "parameters": {
        "language": "javaScript",
        "jsCode": "const item = $node['Passes Validation?'].json;\nlet rawBody = '';\ntry {\n  rawBody = $json.body || '[]';\n} catch(e) {\n  rawBody = '[]';\n}\n\nlet duplicates = [];\ntry {\n  duplicates = JSON.parse(rawBody);\n  if (!Array.isArray(duplicates)) duplicates = [duplicates];\n} catch(e) {\n  duplicates = [];\n}\n\nlet is_duplicate = false;\nlet duplicate_score = 0;\nconst newDomain = item.company_domain || '';\nconst newName = (item.normalized_name || '').toLowerCase();\n\nfor (const dup of duplicates) {\n  let score = 0;\n  if (dup.company_domain === newDomain && newDomain.length > 3) score = 100;\n  if (dup.company_name && newName) {\n    const longer = dup.company_name.length > newName.length ? dup.company_name.toLowerCase() : newName;\n    const shorter = dup.company_name.length > newName.length ? newName : dup.company_name.toLowerCase();\n    let matches = 0;\n    for (let i = 0; i < shorter.length; i++) {\n      if (longer.includes(shorter.substring(i, i + 3))) matches++;\n    }\n    const nameScore = Math.min(100, Math.round((matches * 3 / Math.max(1, shorter.length)) * 100));\n    score = Math.max(score, nameScore);\n  }\n  if (score > duplicate_score) {\n    duplicate_score = score;\n    is_duplicate = score > 80;\n  }\n}\n\nreturn [{ json: { ...item, is_duplicate, duplicate_score, duplicates, duplicate_count: duplicates.length } }];"
      }
    },
