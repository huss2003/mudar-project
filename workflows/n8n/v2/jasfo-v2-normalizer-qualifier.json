    {
      "id": "4c3d4e5f-6a7b-4c9d-0e1f-2a3b4c5d6e7f",
      "name": "Normalize Company Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [650, 300],
      "parameters": {
        "language": "javaScript",
        "jsCode": "const item = $json;\n\nconst rawName = (item.company_name || item.name || '').trim();\nconst rawDomain = (item.company_domain || item.domain || item.url || '').trim();\n\n// Normalize company name: remove extra spaces, legal suffixes\nlet name = rawName\n  .replace(/\\s+/g, ' ')\n  .replace(/\b(Private|Limited|Ltd|LLC|Inc|Corp|Corporation|Pvt|GmbH|Pty|Co)\b\\.?/gi, '')\n  .replace(/[,.]+$/, '')\n  .trim();\n\n// Extract domain from URL if needed\nlet domain = rawDomain;\nif (domain.includes('://')) domain = domain.split('/')[2];\nif (domain.startsWith('www.')) domain = domain.substring(4);\ndomain = domain.split('/')[0].split('?')[0].toLowerCase().trim();\n\nreturn [{ json: { ...item, normalized_name: name || rawName, company_domain: domain, raw_name: rawName, raw_domain: rawDomain } }];"
      }
    },
    {
      "id": "4d4e5f6a-7b8c-4d0e-1f2a-3b4c5d6e7f8a",
      "name": "Check Rejectable Patterns",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [850, 300],
      "parameters": {
        "language": "javaScript",
        "jsCode": "const item = $json;\nconst name = item.normalized_name || '';\nconst domain = item.company_domain || '';\n\nconst rejectPatterns = [\n  /^[a-z]{1,2}$/i, /^test/i, /^sample/i, /^example/i,\n  /\\b(gmail|yahoo|hotmail|outlook|rediff)\\b/i,\n  /\\b(blogger|wordpress|blogspot|wix|weebly)\\b/i,\n  /\\b(wikipedia|facebook|twitter|linkedin|instagram|youtube)\\b/i,\n  /^\\d+$/, /^[^a-zA-Z]+$/, /^[a-z]$/i,\n  /\\b(justdial|sulekha|asklaila|yellowpages|yell|biz)\\b/i\n];\n\nlet is_valid = true;\nlet rejection_reason = '';\n\nif (!name || name.length < 3) {\n  is_valid = false;\n  rejection_reason = 'name_too_short';\n}\n\nif (is_valid) {\n  for (const pattern of rejectPatterns) {\n    if (pattern.test(name) || pattern.test(domain)) {\n      is_valid = false;\n      rejection_reason = 'rejectable_pattern: ' + pattern.source;\n      break;\n    }\n  }\n}\n\nreturn [{ json: { ...item, is_valid, rejection_reason } }];"
      }
    },
