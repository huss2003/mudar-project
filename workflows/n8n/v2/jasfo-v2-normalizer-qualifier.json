    {
      "id": "4e1f2a3b-4c5d-6e7f-8a9b-0c1d2e3f4a5b",
      "name": "Calculate Initial Score",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2050, 350],
      "parameters": {
        "language": "javaScript",
        "jsCode": "const item = $json;\nconst name = (item.company_name || item.normalized_name || '');\nconst domain = (item.company_domain || '');\n\n// Rudimentary initial score based on available signals\nlet score = 30;\nif (domain && domain.includes('.') && domain.length > 6) score += 20;\nif (name && name.length > 5) score += 10;\nif (name && !/\\d{4,}/.test(name)) score += 5;\nif (item.description && item.description.length > 20) score += 10;\nif (item.source_type === 'google_maps') score += 5;\nif (item.source_type === 'indiamart' || item.source_type === 'tradeindia') score += 5;\nif (item.url && item.url.length > 10) score += 10;\nif (item.social_links || item.linkedin) score += 5;\n\nconst finalScore = Math.min(100, Math.max(0, score));\n\nreturn [{ json: { ...item, initial_score: finalScore, scored_at: new Date().toISOString() } }];"
      }
    },
