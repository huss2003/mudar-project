    {
      "id": "77777777-7777-7777-7777-777777777777",
      "name": "Parse Planner Decision",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1680,
        200
      ],
      "parameters": {
        "jsCode": "const response = $json;\nlet content = \"\";\ntry {\n  content = response.choices[0].message.content;\n} catch(e) {\n  content = JSON.stringify(response);\n}\nlet plan = {};\ntry {\n  const m = content.match(/\\{[\\s\\S]*\\}/);\n  plan = m ? JSON.parse(m[0]) : JSON.parse(content);\n} catch(e) {\n  plan = { sources: [\"google_maps\",\"indiamart\",\"tradeindia\"], priority_focus: \"general\" };\n}\nconst prevNode = $(\"Build Planner Prompt\").first().json;\nreturn [{ json: { plan, icp_id: prevNode.icp_id, run_id: prevNode.run_id } }];"
      }
    },
    {
      "id": "88888888-8888-8888-8888-888888888888",
      "name": "Generate 50 Queries",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1920,
        200
      ],
      "parameters": {
        "jsCode": "const item = $json;\nconst plan = item.plan || {};\nconst sources = plan.sources || [\"google_maps\",\"indiamart\",\"tradeindia\"];\nconst focus = plan.priority_focus || \"target\";\nconst geoModifiers = [\"\", \"in India\", \"in Mumbai\", \"in Delhi\", \"in Bangalore\", \"in Pune\"];\nconst synonyms = [\"dealer\", \"distributor\", \"supplier\", \"wholesaler\", \"retailer\", \"stockist\"];\nconst queries = [];\nfor (let i = 0; i < synonyms.length && queries.length < 50; i++) {\n  for (let j = 0; j < geoModifiers.length && queries.length < 50; j++) {\n    const q = [synonyms[i], focus, geoModifiers[j]].filter(Boolean).join(\" \");\n    if (q.trim().length > 3) {\n      queries.push({ query_text: q.trim(), source: sources[queries.length % sources.length], planner_run_id: item.run_id, intent: \"industry+location\", plan: item.plan });\n    }\n  }\n}\nreturn queries.map(q => ({ json: q }));"
      }
    },
