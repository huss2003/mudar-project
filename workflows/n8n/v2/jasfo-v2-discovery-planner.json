    {
      "id": "55555555-5555-5555-5555-555555555555",
      "name": "Build Planner Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1200,
        200
      ],
      "parameters": {
        "jsCode": "const run = $(\"Run Found?\").first().json;\nconst plannerRun = Array.isArray(run) ? run[0] : run;\nconst icpId = plannerRun.icp_id;\nconst runId = plannerRun.id;\n\nconst icpData = $json;\nconst icp = Array.isArray(icpData) ? icpData[0] : icpData;\n\nconst icpName = icp.name || \"Unknown\";\nconst industry = Array.isArray(icp.industry) ? icp.industry.join(\", \") : (icp.industry || \"\");\nconst keywords = Array.isArray(icp.keywords) ? icp.keywords.join(\", \") : \"\";\nconst country = Array.isArray(icp.country) ? icp.country.join(\", \") : \"\";\n\nconst prompt = `You are an ICP discovery planner. Plan a discovery cycle for:\nICP: ${icpName}\nIndustry: ${industry}\nKeywords: ${keywords}\nCountry: ${country}\n\nRespond with JSON only:\n{ \"sources\": [\"google_maps\", \"indiamart\", \"tradeindia\"], \"priority_focus\": \"industry vertical\" }`;\n\nreturn [{ json: { prompt, icp_id: icpId, run_id: runId } }];"
      }
    },
