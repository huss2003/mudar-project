    {
      "id": "2e5f6a7b-8c9d-4e1f-2a3b-4c5d6e7f8a9b",
      "name": "Build Planner Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1050, 300],
      "parameters": {
        "language": "javaScript",
        "jsCode": "const run = $node['Run Found?'].json;\nconst icpData = $json;\nconst icp = {\n  id: icpData.id || run.icp_id,\n  name: icpData.name || 'Unknown',\n  industry: icpData.industry || '',\n  description: icpData.description || '',\n  target_markets: icpData.target_markets || [],\n  keywords: icpData.keywords || []\n};\n\nconst prompt = `You are an ICP discovery planner for Jasfo. Plan a discovery cycle for this ICP:\n\nICP Name: ${icp.name}\nIndustry: ${icp.industry}\nDescription: ${icp.description}\nTarget Markets: ${JSON.stringify(icp.target_markets)}\nKeywords: ${JSON.stringify(icp.keywords)}\n\nRespond with JSON:\n{\n  \"strategy\": \"brief strategy\",\n  \"sources\": [\"google_maps\", \"indiamart\", \"tradeindia\", \"github\", \"rss\"],\n  \"priority_focus\": \"industry vertical\",\n  \"estimated_companies\": number\n}`;\n\nreturn [{ json: { prompt, icp_id: icp.id, run_id: run.id, icp_name: icp.name } }];"
      }
    },
    {
      "id": "2f6a7b8c-9d0e-4f2a-3b4c-5d6e7f8a9b0c",
      "name": "Call OpenCode Planner",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1250, 300],
      "parameters": {
        "method": "POST",
        "url": "https://opencode.ai/zen/go/v1/chat/completions",
        "authentication": "none",
        "sendHeaders": true,
        "headerParameters": {
