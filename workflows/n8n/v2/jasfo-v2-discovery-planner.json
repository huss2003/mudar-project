    {
      "id": "2a7b8c9d-0e1f-4a3b-4c5d-6e7f8a9b0c1d",
      "name": "Parse Planner Decision",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1450, 300],
      "parameters": {
        "language": "javaScript",
        "jsCode": "const response = $json;\nlet content = '';\ntry {\n  content = response.choices[0].message.content;\n} catch (e) {\n  content = response.body || JSON.stringify(response);\n}\n\nlet plan = {};\ntry {\n  const jsonMatch = content.match(/\\{[\\s\\S]*\\}/);\n  plan = jsonMatch ? JSON.parse(jsonMatch[0]) : JSON.parse(content);\n} catch (e) {\n  plan = { strategy: 'default', sources: ['google_maps', 'indiamart', 'tradeindia', 'github', 'rss'], priority_focus: 'general', estimated_companies: 100 };\n}\n\nconst prevNode = $node['Build Planner Prompt'].json;\nreturn [{ json: { plan, icp_id: prevNode.icp_id, run_id: prevNode.run_id, icp_name: prevNode.icp_name } }];"
      }
    },
    {
      "id": "2b8c9d0e-1f2a-4b3c-5d6e-7f8a9b0c1d2e",
      "name": "Generate 50 Search Queries",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1650, 300],
      "parameters": {
        "language": "javaScript",
        "jsCode": "const item = $json;\nconst icpName = item.icp_name || 'target';\nconst industry = (item.plan && item.plan.priority_focus) || 'technology';\nconst sources = (item.plan && item.plan.sources) || ['google_maps', 'indiamart', 'tradeindia', 'github', 'rss'];\n\nconst geoModifiers = ['', 'in India', 'in Mumbai', 'in Delhi', 'in Bangalore', 'in Pune', 'in Hyderabad', 'in Chennai', 'in Ahmedabad', 'in Kolkata', 'in Gurgaon', 'in Noida', 'in India 2025', 'near me', 'in Maharastra', 'in Gujarat', 'in Tamil Nadu', 'in Karnataka'];\nconst intentModifiers = ['best', 'top', 'leading', 'affordable', 'professional', 'reliable', 'trusted', 'expert', 'certified', '', '', ''];\nconst industrySynonyms = [industry, industry + ' services', industry + ' solutions', industry + ' company', industry + ' provider', industry + ' consultant', industry + ' agency', industry + ' firm', industry + ' expert', industry + ' specialist'];\n\nconst queries = [];\nfor (let i = 0; i < 8 && queries.length < 50; i++) {\n  const keyword = industrySynonyms[i % industrySynonyms.length];\n  for (let j = 0; j < geoModifiers.length && queries.length < 50; j++) {\n    const geo = geoModifiers[j];\n    for (let k = 0; k < intentModifiers.length && queries.length < 50; k++) {\n      const intent = intentModifiers[k];\n      const query = [intent, keyword, geo].filter(Boolean).join(' ');\n      if (query.trim().length > 3) {\n        queries.push({\n          query: query.trim(),\n          source: sources[queries.length % sources.length],\n          icp_id: item.icp_id,\n          run_id: item.run_id\n        });\n      }\n    }\n  }\n}\n\nconst sourceCycles = ['google_maps', 'indiamart', 'tradeindia', 'github', 'rss'];\nwhile (queries.length < 50) {\n  for (const src of sourceCycles) {\n    if (queries.length >= 50) break;\n    const modifiers = ['company', 'firm', 'business', 'vendor', 'supplier', 'provider', 'agency', 'service', 'solution', 'consultant'];\n    const m = modifiers[queries.length % modifiers.length];\n    queries.push({\n      query: `${industry} ${m} ${geoModifiers[queries.length % geoModifiers.length]}`.trim(),\n      source: src,\n      icp_id: item.icp_id,\n      run_id: item.run_id\n    });\n  }\n}\n\nreturn [{ json: { queries, icp_id: item.icp_id, run_id: item.run_id, count: queries.length } }];"
      }
    },
