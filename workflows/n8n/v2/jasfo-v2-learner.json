    {
      "id": "5d4e5f6a-7b8c-4d0e-1f2a-3b4c5d6e7f8a",
      "name": "Aggregate Stats Per Source",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [850, 300],
      "parameters": {
        "language": "javaScript",
        "jsCode": "const items = $input.all();\nconst sources = {};\n\nfor (const item of items) {\n  const src = item.json.source_type || 'unknown';\n  if (!sources[src]) {\n    sources[src] = {\n      source_type: src,\n      total_queries: 0,\n      total_companies: 0,\n      accepted_companies: 0,\n      total_runs: 0,\n      last_run: null\n    };\n  }\n  const s = sources[src];\n  s.total_queries += (item.json.queries_executed || 0);\n  s.total_companies += (item.json.companies_discovered || 0);\n  s.accepted_companies += (item.json.companies_accepted || 0);\n  s.total_runs++;\n  const d = item.json.calculated_at || item.json.created_at;\n  if (d && (!s.last_run || d > s.last_run)) s.last_run = d;\n}\n\nconst sourceArray = Object.values(sources);\n\nfor (const s of sourceArray) {\n  s.quality_rate = s.total_companies > 0 ? Math.round((s.accepted_companies / s.total_companies) * 100) : 0;\n  s.efficiency = s.total_queries > 0 ? Math.round(s.total_companies / s.total_queries) : 0;\n  s.priority_score = Math.round((s.quality_rate * 0.7 + Math.min(100, s.efficiency * 20) * 0.3));\n}\n\nsourceArray.sort((a, b) => b.priority_score - a.priority_score);\n\nreturn [{ json: { sources: sourceArray, count: sourceArray.length, best_source: sourceArray[0] || null, worst_source: sourceArray[sourceArray.length - 1] || null } }];"
      }
    },
