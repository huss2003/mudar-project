    {
      "id": "5f6a7b8c-9d0e-4f2a-3b4c-5d6e7f8a9b0c",
      "name": "Generate Performance Report",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1250, 300],
      "parameters": {
        "language": "javaScript",
        "jsCode": "const item = $json;\nconst sources = item.sources || [];\nconst best = sources[0] || null;\nconst worst = sources[sources.length - 1] || null;\n\nlet text = '<b>📊 Source Performance Report</b>\\n\\n';\ntext += '<b>Top Source:</b> ' + (best ? best.source_type + ' (Score: ' + best.priority_score + ', Quality: ' + best.quality_rate + '%)' : 'N/A') + '\\n';\ntext += '<b>Lowest Source:</b> ' + (worst ? worst.source_type + ' (Score: ' + worst.priority_score + ', Quality: ' + worst.quality_rate + '%)' : 'N/A') + '\\n\\n';\ntext += '<b>All Sources:</b>\\n';\n\nfor (const s of sources) {\n  text += '• ' + s.source_type + ': Priority=' + s.priority_score + ', Quality=' + s.quality_rate + '%, Companies=' + s.total_companies + '\\n';\n}\n\ntext += '\\n<i>Next cycle will prioritize high-scoring sources.</i>';\n\nreturn [{ json: { report_text: text, sources_count: sources.length, generated_at: new Date().toISOString() } }];"
      }
