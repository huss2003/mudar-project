    {
      "id": "node-prep-cache-insert",
      "name": "Prep Cache Insert",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [3640, 400],
      "parameters": {
        "jsCode": "const item = $input.first().json;\n\nconst cacheKey = (item.company_domain || item.company_name || 'unknown') + '_profile';\nconst expiresAt = new Date(Date.now() + 7 * 24 * 60 * 60 * 1000).toISOString();\n\nconst cacheBody = JSON.stringify({\n  cache_key: cacheKey,\n  company_domain: item.company_domain || '',\n  source_type: 'company_profile',\n  response_data: item.output_data || {},\n  expires_at: expiresAt\n});\n\nreturn [{\n  json: {\n    ...item,\n    cacheInsertBody: cacheBody\n  }\n}];"
      }
