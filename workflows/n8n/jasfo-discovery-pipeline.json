      "name": "Prep Search Output",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1040, 650],
      "parameters": {
        "jsCode": "const item = $input.first().json;\n\nconst searchResults = item.data || item;\nconst now = new Date().toISOString();\n\nreturn [{\n  json: {\n    ...item,\n    output_data: {\n      run_id: item.run_id,\n      company_name: item.company_name,\n      company_domain: item.company_domain || '',\n      status: 'completed',\n      source: 'search',\n      search_results: searchResults,\n      scraped_at: now\n    },\n    updated_at: now\n  }\n}];"
      }
