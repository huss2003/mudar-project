    {
      "id": "a1b2c3d4-0013-4000-8000-000000000013",
      "name": "Validate Schema",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2800, -150],
      "parameters": {
        "language": "javaScript",
        "code": "const item = $input.first().json;\nconst data = item.parsed_result || item;\n\nconst validated = {\n  company_name: data.company_name || data.name || null,\n  company_description: data.company_description || data.description || null,\n  founded: data.founded || data.founded_year || null,\n  employees: data.employees || data.employee_count || null,\n  location: data.location || data.headquarters || null,\n  technology_stack: data.technology_stack || data.tech_stack || [],\n  products: data.products || [],\n  market_position: data.market_position || data.market_info || null,\n  competitors: data.competitors || [],\n  recent_news: data.recent_news || [],\n  funding: data.funding || null,\n  key_personnel: data.key_personnel || [],\n  confidence_score: data.confidence_score || data.confidence || 0.5\n};\n\nconst validationErrors = [];\nif (!validated.company_name) validationErrors.push('Missing company_name');\n\nreturn [{\n  json: {\n    run_id: item.run_id || '',\n    company_domain: item.company_domain || '',\n    company_data: validated,\n    confidence_scores: {\n      overall: validated.confidence_score,\n      data_completeness: Object.values(validated).filter(v => v !== null && v !== '' && v !== undefined).length / Object.keys(validated).length\n    },\n    model_used: item.model_used || 'deepseek-v4-flash',\n    processing_time_ms: item.processing_time_ms || 0,\n    validation_errors: validationErrors,\n    validation_pass: validationErrors.length === 0\n  }\n}];"
      }
    },
