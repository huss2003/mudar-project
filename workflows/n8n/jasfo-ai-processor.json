    {
      "id": "a1b2c3d4-0006-4000-8000-000000000006",
      "name": "Build AI Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1250, 0],
      "parameters": {
        "language": "javaScript",
        "code": "const item = $input.first().json;\n\nconst runId = item.run_id || '';\nconst domain = item.company_domain || '';\n\nconst scrapedData = item.data && item.data.length > 0 ? item.data[0] : item;\n\ndomain ||= scrapedData.company_domain || '';\n\nconst systemPrompt = `You are a business intelligence analyst. Extract structured company intelligence from the provided scraped data. Return ONLY valid JSON following the schema exactly.`;\n\nconst userPrompt = `Analyze this company data and extract:\n- Company overview (name, description, founded, employees, location)\n- Technology stack and products\n- Market position and competitors\n- Recent news and funding\n- Key personnel\n\nCompany data:\n${JSON.stringify(scrapedData, null, 2)}`;\n\nconst fullText = systemPrompt + userPrompt;\nconst estimatedTokens = Math.ceil(fullText.length / 4);\n\nreturn [{\n  json: {\n    run_id: runId,\n    company_domain: domain,\n    system_prompt: systemPrompt,\n    user_prompt: userPrompt,\n    estimatedTokens: estimatedTokens,\n    raw_data: scrapedData\n  }\n}];"
      }
