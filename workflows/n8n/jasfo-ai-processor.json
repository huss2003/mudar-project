    {
      "id": "6e8f1a2b-3c4d-5e6f-7a8b-9c0d1e2f3a4b",
      "name": "Build AI Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 1,
      "position": [250, 1100],
      "parameters": {
        "jsCode": "const item = $json;\nconst scrapeList = Array.isArray(item) ? item : [item];\nconst data = scrapeList[0] || item;\nconst scrapeData = data.scrape_data || {};\nconst content = scrapeData.content || data.content || '';\nconst url = scrapeData.url || data.url || '';\nconst title = scrapeData.title || data.title || '';\nconst estimatedTokens = content.length;\n\nlet model = 'deepseek-v4-flash';\nif (estimatedTokens > 100000) {\n  model = 'mimo-v2.5';\n}\n\nconst systemPrompt = 'You are an expert business analyst. Extract structured intelligence from web content including company identification, industry classification, key insights, and confidence scoring. Return valid JSON only.';\n\nconst userPrompt = 'URL: ' + url + '\\nTitle: ' + title + '\\n\\nContent:\\n' + content.substring(0, 150000) + '\\n\\nAnalyze this content and extract structured intelligence as JSON with fields: company_name, industry, summary, key_insights (array), confidence_score (0-100).';\n\nconst messages = [\n  { role: 'system', content: systemPrompt },\n  { role: 'user', content: userPrompt }\n];\n\nreturn {\n  ...data,\n  messages,\n  model,\n  estimatedTokens\n};"
      }
    },
