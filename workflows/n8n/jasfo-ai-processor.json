    {
      "id": "8a0b1c2d-3e4f-5a6b-7c8d-9e0f1a2b3c4d",
      "name": "Parse And Validate",
      "type": "n8n-nodes-base.code",
      "typeVersion": 1,
      "position": [250, 1500],
      "parameters": {
        "jsCode": "const response = $json;\nconst rawContent = response.choices && response.choices[0] && response.choices[0].message && response.choices[0].message.content ? response.choices[0].message.content : '';\n\nif (!rawContent) {\n  throw new Error('Empty response from AI');\n}\n\nlet parsed;\ntry {\n  parsed = JSON.parse(rawContent);\n} catch (e) {\n  throw new Error('Failed to parse AI response: ' + e.message);\n}\n\nconst requiredFields = ['company_name', 'industry', 'summary', 'key_insights', 'confidence_score'];\nfor (const field of requiredFields) {\n  if (parsed[field] === undefined || parsed[field] === null) {\n    throw new Error('Missing required field: ' + field);\n  }\n}\n\nreturn {\n  ...response,\n  extraction: parsed,\n  raw_response: rawContent\n};"
      }
