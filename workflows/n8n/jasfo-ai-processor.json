    {
      "id": "a1b2c3d4-0010-4000-8000-000000000010",
      "name": "Parse JSON Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2050, 0],
      "parameters": {
        "language": "javaScript",
        "code": "const item = $input.first().json;\n\nlet parsed = null;\nlet parseError = null;\n\nconst content = item.choices && item.choices[0] && item.choices[0].message && item.choices[0].message.content;\n\nif (!content) {\n  parseError = 'No content in response';\n} else {\n  try {\n    parsed = JSON.parse(content);\n  } catch (e) {\n    try {\n      const cleaned = content.replace(/```json\\n?/g, '').replace(/```\\n?/g, '').trim();\n      parsed = JSON.parse(cleaned);\n    } catch (e2) {\n      parseError = 'Failed to parse response: ' + e2.message;\n    }\n  }\n}\n\nreturn [{\n  json: {\n    run_id: item.run_id || $json.run_id || '',\n    company_domain: item.company_domain || $json.company_domain || '',\n    parsed_result: parsed,\n    parse_error: parseError,\n    parse_success: parseError === null,\n    raw_response: content || '',\n    model_used: item.model || 'deepseek-v4-flash',\n    processing_time_ms: item.processing_time_ms || 0\n  }\n}];"
      }
    },
