      "id": "merge-data",
      "name": "Merge Scraped Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2850, 550],
      "parameters": {
        "language": "javaScript",
        "code": "var pollResult = $node['Poll Crawl Status'].json;\nvar aboutResult = $node['Firecrawl Scrape About'].json;\nvar searchResult = $json;\nvar companyInfo = $node['Extract Company Info'].json;\n\nvar expDate = new Date();\nexpDate.setDate(expDate.getDate() + 7);\n\nvar merged = {\n  crawlStatus: pollResult.crawlStatus,\n  crawlPages: pollResult.pages || [],\n  totalCrawled: pollResult.totalPages || 0,\n  aboutData: aboutResult.data || aboutResult,\n  searchData: searchResult.data || searchResult,\n  companyDomain: companyInfo.companyDomain,\n  companyName: companyInfo.companyName,\n  fetchedAt: new Date().toISOString()\n};\n\nreturn [{\n  mergedData: merged,\n  companyDomain: companyInfo.companyDomain,\n  companyName: companyInfo.companyName,\n  runId: companyInfo.runId,\n  cacheKey: companyInfo.companyDomain + '_profile',\n  expiresAt: expDate.toISOString()\n}];"
