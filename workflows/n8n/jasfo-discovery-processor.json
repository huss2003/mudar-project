        "sendBody": true,
        "bodyContentType": "json",
        "bodyParameters": { "parameters": [{ "name": "url", "value": "={{ 'https://' + $json.company_domain }}" }, { "name": "maxDepth", "value": 2 }, { "name": "maxPages", "value": 10 }, { "name": "scrapeOptions", "value": "={ \"formats\": [\"markdown\"] }" }] },
