      "id": "extract-crawl-id",
      "name": "Extract Crawl ID",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2050, 550],
      "parameters": {
        "language": "javaScript",
        "code": "const item = $json;\nreturn [{\n  crawlId: item.id,\n  companyDomain: $node['Extract Company Info'].json.companyDomain,\n  companyName: $node['Extract Company Info'].json.companyName,\n  runId: $node['Extract Company Info'].json.runId\n}];"
