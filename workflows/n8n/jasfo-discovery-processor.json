    {
      "id": "poll-crawl",
      "name": "Poll Crawl Status",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2250, 550],
      "parameters": {
        "language": "javaScript",
        "code": "const item = $json;\nconst crawlId = item.crawlId;\nconst maxAttempts = 30;\nconst intervalMs = 5000;\nconst sleep = (ms) => new Promise(resolve => setTimeout(resolve, ms));\n\nif (!crawlId) {\n  return [{\n    crawlStatus: 'skipped',\n    pages: [],\n    companyDomain: item.companyDomain,\n    companyName: item.companyName,\n    runId: item.runId\n  }];\n}\n\nfor (let attempt = 0; attempt < maxAttempts; attempt++) {\n  try {\n    const data = await this.helpers.httpRequest({\n      method: 'GET',\n      url: 'https://api.firecrawl.dev/v1/crawl/' + crawlId,\n      headers: {\n        'Authorization': 'Bearer fc-03ee582d75c647c59555df35374d8fa2'\n      }\n    });\n\n    if (data.status === 'completed') {\n      return [{\n        crawlStatus: 'completed',\n        pages: data.data || [],\n        totalPages: (data.data || []).length,\n        companyDomain: item.companyDomain,\n        companyName: item.companyName,\n        runId: item.runId\n      }];\n    }\n\n    if (data.status === 'failed' || data.status === 'error') {\n      return [{\n        crawlStatus: 'failed',\n        pages: [],\n        error: data.error || 'Crawl failed',\n        companyDomain: item.companyDomain,\n        companyName: item.companyName,\n        runId: item.runId\n      }];\n    }\n\n    await sleep(intervalMs);\n  } catch (err) {\n    if (attempt === maxAttempts - 1) {\n      return [{\n        crawlStatus: 'error',\n        pages: [],\n        error: err.message,\n        companyDomain: item.companyDomain,\n        companyName: item.companyName,\n        runId: item.runId\n      }];\n    }\n    await sleep(intervalMs);\n  }\n}\n\nreturn [{\n  crawlStatus: 'timeout',\n  pages: [],\n  companyDomain: item.companyDomain,\n  companyName: item.companyName,\n  runId: item.runId\n}];"
      }
    },
