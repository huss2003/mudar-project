      "parameters": {
        "language": "javaScript",
        "code": "var item = $json;\nvar companyDomain = item.companyDomain || $node['Extract Company Info'].json.companyDomain;\nvar runId = item.runId || $node['Extract Company Info'].json.runId;\nvar companyName = item.companyName || $node['Extract Company Info'].json.companyName;\nvar scrapeSummary = {};\n\nif (item.response_data) {\n  scrapeSummary = typeof item.response_data === 'string'\n    ? JSON.parse(item.response_data)\n    : item.response_data;\n} else if (item.mergedData) {\n  scrapeSummary = item.mergedData;\n} else {\n  scrapeSummary = {\n    crawlStatus: $node['Poll Crawl Status'].json.crawlStatus || 'no_data',\n    aboutData: $node['Firecrawl Scrape About'].json.data || null,\n    searchData: $json.data || null\n  };\n}\n\nreturn [{\n  runId: runId,\n  companyDomain: companyDomain,\n  companyName: companyName,\n  status: 'completed',\n  nextStep: 'ai_ready',\n  scrapeSummary: scrapeSummary,\n  updatedAt: new Date().toISOString()\n}];"
