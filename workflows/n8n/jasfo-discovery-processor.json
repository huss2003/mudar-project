    {
      "id": "a1b2c3d4-e5f6-4a90-abcd-000000000009",
      "name": "Merge Scraped Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1650, 300],
      "parameters": {
        "language": "javaScript",
        "code": "const item = $input.first().json;\nconst crawlResult = $node['Firecrawl Crawl'].json || {};\nconst scrapeResult = $node['Firecrawl Scrape'].json || {};\nconst cacheResult = $node['Check Cache'].json;\nconst cacheHit = Array.isArray(cacheResult) && cacheResult.length > 0;\n\nreturn [{\n  json: {\n    company_domain: item.company_domain,\n    company_name: item.company_name,\n    run_id: item.run_id,\n    cached: cacheHit,\n    crawl_data: crawlResult.data || crawlResult,\n    scrape_data: scrapeResult.data || scrapeResult,\n    merged_at: new Date().toISOString()\n  }\n}];"
      }
    },
