    {
      "id": "code-003",
      "name": "Validate Companies",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [650, 300],
      "parameters": {
        "language": "javascript",
        "runOnceForAllItems": true,
        "code": "const items = $input.all();\n\nlet validCount = 0;\nconst output = [];\nconst runId = 'run_' + Date.now() + '_' + Math.random().toString(36).substring(2, 11);\n\nfor (const item of items) {\n  const company = item.json;\n  const name = company.company_name || '';\n\n  if (name.length >= 2) {\n    validCount++;\n    output.push({\n      json: {\n        ...company,\n        run_id: runId,\n        validated: true\n      }\n    });\n  }\n}\n\noutput.push({\n  json: {\n    validated: false,\n    run_id: runId,\n    count: validCount,\n    message: 'meta'\n  }\n});\n\nreturn output;"
      }
    },
    {
      "id": "if-004",
      "name": "Route Valid Companies",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [850, 300],
      "parameters": {
        "conditions": {
          "options": {},
          "conditions": [
            {
              "id": "cond-validated-true",
              "leftValue": "={{ $json.validated }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equal"
              }
            }
          ]
        }
      }
    },
