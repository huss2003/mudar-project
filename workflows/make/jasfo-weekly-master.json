        "to": 4,
        "from_port": 0,
        "to_port": 0,
        "metadata": {
          "label": "Valid (name exists & length >= 2)"
        },
        "filter": {
          "operator": "and",
          "conditions": [
            {
              "field": "company_name",
              "operator": "exists",
              "value": true
            },
            {
              "field": "company_name",
              "operator": "length_gte",
              "value": 2
            }
          ]
        }
      },
      {
        "id": 4,
