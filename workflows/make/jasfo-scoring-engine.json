{
  "name": "Jasfo - Scoring Engine",
  "description": "8-pillar AI scoring with consensus and reflection",
  "metadata": { "version": 1 },
  "blueprint": {
    "modules": [
      {
        "id": 1,
        "module": "webhook:custom",
        "label": "Receive scoring request",
        "parameters": {
          "dataType": "json",
          "webhookUrl": "/hook/jasfo-score"
        },
        "output": {
          "company_id": "{{webhook.company_id}}",
          "company_name": "{{webhook.company_name}}",
          "user_id": "{{webhook.user_id}}",
          "source": "{{webhook.source}}"
        }
      },
      {
        "id": 2,
        "module": "supabase:selectRows",
        "label": "Load AI extraction data",
        "parameters": {
          "connection": "Jasfo Supabase",
          "table": "ai_extraction_data",
          "filter": {
            "company_id": "{{1.company_id}}"
          },
          "limit": 1,
          "sort": [
            { "column": "created_at", "direction": "desc" }
          ]
        },
        "output": {
          "extraction_id": "{{2.id}}",
          "company_data": "{{2.data}}",
          "created_at": "{{2.created_at}}"
        }
      },
      {
        "id": 3,
        "module": "textparser:textAggregator",
        "label": "Build scoring context",
        "parameters": {
          "mode": "advanced",
          "items": [
            { "key": "company_name", "value": "{{1.company_name}}" },
            { "key": "industry", "value": "{{2.industry}}" },
            { "key": "size", "value": "{{2.size}}" },
            { "key": "revenue", "value": "{{2.revenue}}" },
            { "key": "employees", "value": "{{2.employees}}" },
            { "key": "location", "value": "{{2.location}}" },
            { "key": "growth_rate", "value": "{{2.growth_rate}}" },
            { "key": "funding", "value": "{{2.funding}}" },
            { "key": "decision_makers", "value": "{{2.decision_makers}}" },
            { "key": "real_estate_needs", "value": "{{2.real_estate_needs}}" },
            { "key": "lease_expiry", "value": "{{2.lease_expiry}}" },
            { "key": "move_timeline", "value": "{{2.move_timeline}}" },
            { "key": "network_connections", "value": "{{2.network_connections}}" },
            { "key": "evidence_sources", "value": "{{2.evidence_sources}}" },
            { "key": "opportunity_signals", "value": "{{2.opportunity_signals}}" }
          ],
          "delimiter": "\n"
        },
        "output": {
          "context": "{{3.text}}"
        }
      },
      {
        "id": 4,
        "module": "http:request",
        "label": "Score: Company Fit (10%)",
        "parameters": {
          "method": "POST",
          "url": "https://opencode.ai/zen/go/v1/chat/completions",
          "headers": {
            "Authorization": "Bearer sk-MmeX9RLWQrIFngobzyoLIoVjLx58ObW5ZhUmqYbwhPucZc8Nn46jQbvw4Vuf2yCA",
            "Content-Type": "application/json"
          },
          "body": {
            "model": "deepseek-v4-flash",
            "messages": [
              {
                "role": "system",
                "content": "You are a commercial real estate scoring AI. Score companies on Company Fit for CRE lead generation. Return JSON with score (0-100), reasoning, and signals."
              },
              {
                "role": "user",
                "content": "Company: {{1.company_name}}\nData: {{3.context}}\n\nScore pillar: Company Fit (weight: 10%)\nEvaluate industry relevance to commercial real estate, company maturity, location match, and likelihood of needing space solutions."
              }
            ],
            "response_format": { "type": "json_object" },
            "temperature": 0.2,
            "max_tokens": 2000
          }
        },
        "output": {
          "raw_response": "{{4.data}}"
        }
      },
