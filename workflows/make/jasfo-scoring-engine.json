      {
        "id": 22,
        "module": "http:request",
        "label": "Consensus & Reflection (MiMo V2.5)",
        "parameters": {
          "method": "POST",
          "url": "https://api.mimo.com/v2.5/chat/completions",
          "headers": {
            "Authorization": "Bearer sk-MmeX9RLWQrIFngobzyoLIoVjLx58ObW5ZhUmqYbwhPucZc8Nn46jQbvw4Vuf2yCA",
            "Content-Type": "application/json"
          },
          "body": {
            "model": "mimo-v2.5",
            "messages": [
              {
                "role": "system",
                "content": "You are a consensus and reflection AI for commercial real estate scoring. Review the 8 pillar scores, weighted composite, and previous scores. Validate consistency, flag anomalies, and provide a pass/fail verdict with reasoning. Return JSON with: passed (boolean), reflection_notes, anomalies (array), adjusted_composite (number or null), recommendation."
              },
              {
                "role": "user",
                "content": "Review these scores for {{1.company_name}}:\n\nPillar Scores:\n1. Company Fit: {{12.score}}/100 (weight 10%)\n2. Move Intent: {{13.score}}/100 (weight 35%)\n3. Growth: {{14.score}}/100 (weight 15%)\n4. Financial: {{15.score}}/100 (weight 12%)\n5. Decision Maker: {{16.score}}/100 (weight 10%)\n6. Network: {{17.score}}/100 (weight 8%)\n7. Opportunity: {{18.score}}/100 (weight 5%)\n8. Evidence: {{19.score}}/100 (weight 5%)\n\nCalculated Composite: {{21.composite_score}}\nPrevious Composite: {{20.composite_score}}\n\nCheck for:\n- Internal consistency between pillars\n- Anomalies or outliers\n- Sudden changes from previous score\n- Data quality issues\n- Conflicting signals\n\nProvide pass/fail and actionable reflection."
              }
            ],
            "response_format": { "type": "json_object" },
            "temperature": 0.3,
            "max_tokens": 3000
          }
        },
        "output": {
          "reflection_raw": "{{22.data}}"
        }
      },
      {
        "id": 23,
        "module": "textparser:parseJSON",
        "label": "Parse reflection result",
        "parameters": {
          "text": "{{22.reflection_raw}}",
          "parseMode": "once"
        },
        "output": {
          "passed": "{{23.passed}}",
          "reflection_notes": "{{23.reflection_notes}}",
          "anomalies": "{{23.anomalies}}",
          "adjusted_composite": "{{23.adjusted_composite}}",
          "recommendation": "{{23.recommendation}}"
        }
      },
      {
        "id": 24,
        "module": "router:router",
        "label": "Route on reflection pass/fail",
        "parameters": {
          "routes": [
            {
              "label": "Pass",
              "condition": "{{23.passed}} === true"
            },
            {
              "label": "Fail",
              "default": true
            }
          ]
        }
      },
      {
        "id": 25,
        "module": "supabase:insertRow",
        "label": "Store score card",
        "parameters": {
          "connection": "Jasfo Supabase",
          "table": "score_cards",
          "data": {
            "company_id": "{{1.company_id}}",
            "company_name": "{{1.company_name}}",
            "user_id": "{{1.user_id}}",
            "source": "{{1.source}}",
            "extraction_id": "{{2.id}}",
            "composite_score": "{{23.adjusted_composite || 21.composite_formula}}",
            "scores": {
              "company_fit": { "score": "{{12.score}}", "reasoning": "{{12.reasoning}}", "signals": "{{12.signals}}", "weight": 10 },
              "move_intent": { "score": "{{13.score}}", "reasoning": "{{13.reasoning}}", "signals": "{{13.signals}}", "weight": 35 },
              "growth": { "score": "{{14.score}}", "reasoning": "{{14.reasoning}}", "signals": "{{14.signals}}", "weight": 15 },
              "financial": { "score": "{{15.score}}", "reasoning": "{{15.reasoning}}", "signals": "{{15.signals}}", "weight": 12 },
              "decision_maker": { "score": "{{16.score}}", "reasoning": "{{16.reasoning}}", "signals": "{{16.signals}}", "weight": 10 },
