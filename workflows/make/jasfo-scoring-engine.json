        }
      },
      {
        "id": 21,
        "module": "textparser:textAggregator",
        "label": "Combine scores & calculate composite",
        "parameters": {
          "mode": "advanced",
          "items": [
            { "key": "company_id", "value": "{{1.company_id}}" },
            { "key": "company_name", "value": "{{1.company_name}}" },
            { "key": "company_fit_score", "value": "{{12.score}}" },
            { "key": "company_fit_reasoning", "value": "{{12.reasoning}}" },
            { "key": "company_fit_signals", "value": "{{12.signals}}" },
            { "key": "company_fit_weight", "value": "10" },
            { "key": "move_intent_score", "value": "{{13.score}}" },
            { "key": "move_intent_reasoning", "value": "{{13.reasoning}}" },
            { "key": "move_intent_signals", "value": "{{13.signals}}" },
            { "key": "move_intent_weight", "value": "35" },
            { "key": "growth_score", "value": "{{14.score}}" },
            { "key": "growth_reasoning", "value": "{{14.reasoning}}" },
            { "key": "growth_signals", "value": "{{14.signals}}" },
            { "key": "growth_weight", "value": "15" },
            { "key": "financial_score", "value": "{{15.score}}" },
            { "key": "financial_reasoning", "value": "{{15.reasoning}}" },
            { "key": "financial_signals", "value": "{{15.signals}}" },
            { "key": "financial_weight", "value": "12" },
            { "key": "decision_maker_score", "value": "{{16.score}}" },
            { "key": "decision_maker_reasoning", "value": "{{16.reasoning}}" },
            { "key": "decision_maker_signals", "value": "{{16.signals}}" },
            { "key": "decision_maker_weight", "value": "10" },
            { "key": "network_score", "value": "{{17.score}}" },
            { "key": "network_reasoning", "value": "{{17.reasoning}}" },
            { "key": "network_signals", "value": "{{17.signals}}" },
            { "key": "network_weight", "value": "8" },
            { "key": "opportunity_score", "value": "{{18.score}}" },
            { "key": "opportunity_reasoning", "value": "{{18.reasoning}}" },
            { "key": "opportunity_signals", "value": "{{18.signals}}" },
            { "key": "opportunity_weight", "value": "5" },
            { "key": "evidence_score", "value": "{{19.score}}" },
            { "key": "evidence_reasoning", "value": "{{19.reasoning}}" },
            { "key": "evidence_signals", "value": "{{19.signals}}" },
            { "key": "evidence_weight", "value": "5" },
            { "key": "existing_composite", "value": "{{20.composite_score}}" },
            { "key": "existing_scores_raw", "value": "{{20.scores}}" }
          ],
          "delimiter": "\n",
          "composite_formula": "({{12.score}} * 0.10) + ({{13.score}} * 0.35) + ({{14.score}} * 0.15) + ({{15.score}} * 0.12) + ({{16.score}} * 0.10) + ({{17.score}} * 0.08) + ({{18.score}} * 0.05) + ({{19.score}} * 0.05)"
        },
        "output": {
          "aggregated_scores": "{{21.text}}",
          "composite_score": "{{21.composite_formula}}"
        }
