{
  "name": "Jasfo - Export & Delivery",
  "description": "Format and deliver lead intelligence reports via Telegram",
  "metadata": { "version": 1 },
  "blueprint": {
    "modules": [
      {
        "id": 1,
        "module": "webhook:customWebhook",
        "label": "Receive export request",
        "__moduleConfig": {
          "mapping": {
            "run_id": "{{webhook.body.run_id}}",
            "company_domain": "{{webhook.body.company_domain}}",
            "export_format": "{{webhook.body.export_format}}",
            "score_card_id": "{{webhook.body.score_card_id}}"
          },
          "trigger": true,
          "dataType": "json"
        },
        "parameters": {
          "webhook": "jasfo-export-trigger"
        },
        "output": {
          "run_id": "{{webhook.body.run_id}}",
          "company_domain": "{{webhook.body.company_domain}}",
          "export_format": "{{webhook.body.export_format}}",
          "score_card_id": "{{webhook.body.score_card_id}}"
        }
      },
      {
        "id": 2,
        "module": "supabase:selectRows",
        "label": "Get score card by ID",
        "__moduleConfig": {
          "mapping": {
            "table": "score_cards",
            "select": "*",
            "match": { "id": "{{1.score_card_id}}" }
          },
          "limit": 1
        },
        "parameters": {
          "connection": "jasfo_supabase",
          "table": "score_cards",
          "match": { "id": "{{1.score_card_id}}" },
          "limit": 1
        },
        "output": {
          "score_card": "{{2.data}}"
        }
      },
      {
        "id": 3,
        "module": "supabase:selectRows",
        "label": "Get AI extraction by domain + run",
        "__moduleConfig": {
          "mapping": {
            "table": "ai_extractions",
            "select": "*",
            "match": {
              "company_domain": "{{1.company_domain}}",
              "run_id": "{{1.run_id}}"
            }
          },
          "limit": 1
        },
        "parameters": {
          "connection": "jasfo_supabase",
          "table": "ai_extractions",
          "match": {
            "company_domain": "{{1.company_domain}}",
            "run_id": "{{1.run_id}}"
          },
          "limit": 1
        },
        "output": {
          "ai_extraction": "{{3.data}}"
        }
      },
      {
        "id": 4,
        "module": "supabase:selectRows",
        "label": "Get company by domain",
        "__moduleConfig": {
          "mapping": {
            "table": "companies",
            "select": "*",
            "match": { "domain": "{{1.company_domain}}" }
          },
          "limit": 1
        },
        "parameters": {
          "connection": "jasfo_supabase",
          "table": "companies",
          "match": { "domain": "{{1.company_domain}}" },
          "limit": 1
        },
        "output": {
          "company": "{{4.data}}"
        }
      },
      {
        "id": 5,
        "module": "aggregator:textAggregator",
        "label": "Merge all data into single object",
        "__moduleConfig": {
          "aggregation": "all",
          "outputType": "structured"
        },
        "parameters": {
          "aggregator": {
            "run_id": "{{1.run_id}}",
            "company_domain": "{{1.company_domain}}",
            "export_format": "{{1.export_format}}",
            "score_card_id": "{{1.score_card_id}}",
            "score_card": "{{2.score_card}}",
            "ai_extraction": "{{3.ai_extraction}}",
            "company": "{{4.company}}"
          }
        },
        "output": {
          "merged": "{{5.aggregator}}"
        }
      },
      {
        "id": 6,
        "module": "router:router",
        "label": "Route by export format",
        "__moduleConfig": {
          "routing": {
            "field": "{{5.merged.export_format}}",
            "routes": {
              "json": { "next": [7] },
              "csv": { "next": [8] },
              "markdown": { "next": [9] },
              "telegram": { "next": [10] }
            }
          }
        },
        "parameters": {
          "routing": {
            "field": "{{5.merged.export_format}}",
            "routes": {
              "json": { "next": [7] },
              "csv": { "next": [8] },
              "markdown": { "next": [9] },
              "telegram": { "next": [10] }
            }
          }
        }
      },
      {
        "id": 7,
        "module": "aggregator:textAggregator",
        "label": "Build JSON report",
        "__moduleConfig": {
          "aggregation": "single",
          "outputType": "text"
        },
        "parameters": {
          "aggregator": "{{{json .5.merged}}}"
        },
        "output": {
          "json_report": "{{7.aggregator}}"
        }
      },
      {
        "id": 8,
        "module": "aggregator:textAggregator",
        "label": "Build CSV row",
        "__moduleConfig": {
          "aggregation": "single",
          "outputType": "text"
        },
        "parameters": {
          "aggregator": "company_name,domain,composite_score,confidence,score1,score2,score3,score4,score5,score6,score7,score8,run_id,exported_at\n{{4.company.name}},{{4.company.domain}},{{2.score_card.composite_score}},{{2.score_card.confidence}},{{2.score_card.score1}},{{2.score_card.score2}},{{2.score_card.score3}},{{2.score_card.score4}},{{2.score_card.score5}},{{2.score_card.score6}},{{2.score_card.score7}},{{2.score_card.score8}},{{1.run_id}},{{formatDate now \"YYYY-MM-DDTHH:mm:ssZ\"}}"
        },
        "output": {
          "csv_row": "{{8.aggregator}}"
        }
      },
      {
        "id": 9,
        "module": "aggregator:textAggregator",
        "label": "Build Markdown report",
        "__moduleConfig": {
          "aggregation": "single",
          "outputType": "text"
        },
        "parameters": {
          "aggregator": "# Jasfo Intelligence Report\n\n**Company:** {{4.company.name}}\n**Domain:** {{4.company.domain}}\n**Run ID:** {{1.run_id}}\n**Date:** {{formatDate now \"YYYY-MM-DD\"}}\n\n## Composite Score\n**{{2.score_card.composite_score}}/100** — {{2.score_card.confidence}}\n\n## Pillar Scores\n| Pillar | Score |\n|--------|------|\n| Company Fit | {{2.score_card.score1}} |\n| Move Intent | {{2.score_card.score2}} |\n| Growth | {{2.score_card.score3}} |\n| Financial | {{2.score_card.score4}} |\n| Decision Maker | {{2.score_card.score5}} |\n| Network | {{2.score_card.score6}} |\n| Opportunity | {{2.score_card.score7}} |\n| Evidence | {{2.score_card.score8}} |\n\n## Risk Factors\n{{2.score_card.risk_summary}}\n\n---\n*Generated by Jasfo Intelligence Engine*"
        },
        "output": {
          "markdown_report": "{{9.aggregator}}"
        }
      },
      {
        "id": 10,
        "module": "aggregator:textAggregator",
        "label": "Build Telegram message",
        "__moduleConfig": {
          "aggregation": "single",
          "outputType": "text"
        },
        "parameters": {
          "aggregator": "📊 *{{4.company.name}}*\nScore: {{2.score_card.composite_score}}/100 — {{2.score_card.confidence}}\n\n*Pillar Scores*\nCompany Fit: {{2.score_card.score1}} | Move Intent: {{2.score_card.score2}}\nGrowth: {{2.score_card.score3}} | Financial: {{2.score_card.score4}}\nDecision Maker: {{2.score_card.score5}} | Network: {{2.score_card.score6}}\nOpportunity: {{2.score_card.score7}} | Evidence: {{2.score_card.score8}}\n\n*Risk Factors*\n{{2.score_card.risk_summary}}\n\n🔗 [Full Report](https://jasfo.app/report/{{1.run_id}})"
        },
        "output": {
          "telegram_message": "{{10.aggregator}}"
        }
      },
      {
        "id": 11,
        "module": "telegram:sendMessage",
        "label": "Send report to Telegram channel",
        "__moduleConfig": {
          "mapping": {
            "message": "{{10.aggregator}}",
            "parse_mode": "Markdown",
            "chat_id": "@jasfo_alerts",
            "disable_web_page_preview": false
          }
        },
        "parameters": {
          "connection": "jasfo_telegram_bot",
          "chat_id": "@jasfo_alerts",
          "message": "{{10.aggregator}}",
          "parse_mode": "Markdown",
          "disable_web_page_preview": false
        },
        "output": {
          "telegram_response": "{{11.data}}"
        }
      },
      {
        "id": 12,
        "module": "supabase:insertRow",
        "label": "Archive report to report_archive",
        "__moduleConfig": {
          "mapping": {
            "table": "report_archive",
            "record": {
              "run_id": "{{1.run_id}}",
              "company_domain": "{{1.company_domain}}",
              "score_card_id": "{{1.score_card_id}}",
              "export_format": "{{1.export_format}}",
              "report_json": "{{5.merged}}",
              "composite_score": "{{2.score_card.composite_score}}",
              "company_name": "{{4.company.name}}",
              "confidence": "{{2.score_card.confidence}}",
              "archived_at": "{{formatDate now \"YYYY-MM-DDTHH:mm:ssZ\"}}"
            }
          }
        },
        "parameters": {
          "connection": "jasfo_supabase",
          "table": "report_archive",
          "record": {
            "run_id": "{{1.run_id}}",
            "company_domain": "{{1.company_domain}}",
            "score_card_id": "{{1.score_card_id}}",
            "export_format": "{{1.export_format}}",
            "report_json": "{{5.merged}}",
            "composite_score": "{{2.score_card.composite_score}}",
            "company_name": "{{4.company.name}}",
            "confidence": "{{2.score_card.confidence}}",
            "archived_at": "{{formatDate now \"YYYY-MM-DDTHH:mm:ssZ\"}}"
          }
        },
        "output": {
          "archive_row": "{{12.data}}"
        }
      },
      {
        "id": 13,
        "module": "supabase:updateRows",
        "label": "Mark scenario_queue completed",
        "__moduleConfig": {
          "mapping": {
            "table": "scenario_queue",
            "match": { "run_id": "{{1.run_id}}" },
            "update": { "status": "completed", "completed_at": "{{formatDate now \"YYYY-MM-DDTHH:mm:ssZ\"}}" }
          }
        },
        "parameters": {
          "connection": "jasfo_supabase",
          "table": "scenario_queue",
          "match": { "run_id": "{{1.run_id}}" },
          "update": { "status": "completed", "completed_at": "{{formatDate now \"YYYY-MM-DDTHH:mm:ssZ\"}}" }
        },
        "output": {
          "updated_queue": "{{13.data}}"
        }
      }
    ],
    "connections": [
      { "id": 1, "from": 1, "to": 2 },
      { "id": 2, "from": 2, "to": 3 },
      { "id": 3, "from": 3, "to": 4 },
      { "id": 4, "from": 4, "to": 5 },
      { "id": 5, "from": 5, "to": 6 },
      { "id": 6, "from": 6, "to": 7, "metadata": { "route": "json" } },
      { "id": 7, "from": 6, "to": 8, "metadata": { "route": "csv" } },
      { "id": 8, "from": 6, "to": 9, "metadata": { "route": "markdown" } },
      { "id": 9, "from": 6, "to": 10, "metadata": { "route": "telegram" } },
      { "id": 10, "from": 7, "to": 12 },
      { "id": 11, "from": 8, "to": 12 },
      { "id": 12, "from": 9, "to": 12 },
      { "id": 13, "from": 10, "to": 11 },
      { "id": 14, "from": 11, "to": 12 },
      { "id": 15, "from": 12, "to": 13 }
    ],
    "storage": {}
  }
}